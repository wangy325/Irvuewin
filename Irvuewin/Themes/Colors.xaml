<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Colors -->
    <Color x:Key="AccentColor">#3585FF</Color>
    <Color x:Key="MouseOnColor">LightGray</Color>
    <Color x:Key="ButtonMouseOnColor">Gray</Color>
    <Color x:Key="DangerColor">#FFF44336</Color>
    <Color x:Key="ScrollBarThumbColor">#bcbcbc</Color>
    <Color x:Key="ScrollBarThumbMouseOverColor">#888888</Color>
    
    <!-- Brushes -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="WhiteSmoke"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="White"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="Black"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="Gray"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="White"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource MouseOnColor}"/>
    <SolidColorBrush x:Key="ControlMouseOverBrush" Color="{StaticResource MouseOnColor}"/>
    <SolidColorBrush x:Key="ButtonMouseOverBrush" Color="{StaticResource ButtonMouseOnColor}"/>
    <SolidColorBrush x:Key="ControlDisabledForegroundBrush" Color="{StaticResource ButtonMouseOnColor}"/>
    <SolidColorBrush x:Key="ControlDisabledBackgroundBrush" Color="{StaticResource MouseOnColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#33000000"/> <!-- For shadows or subtle borders -->
    
    <!-- Special Brushes -->
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="DarkTextBrush" Color="#333333"/>
    <SolidColorBrush x:Key="MediumTextBrush" Color="#555555"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="#FF3585FF"/> <!-- Same as Accent, used for radio dots etc. -->
    
    <!-- ScrollBar Brushes -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#bcbcbc"/>
    <SolidColorBrush x:Key="ScrollBarThumbMouseOverBrush" Color="#888888"/>

</ResourceDictionary>
