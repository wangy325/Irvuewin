<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Colors -->
    <Color x:Key="AccentColor">#3585FF</Color>
    <Color x:Key="MouseOnColor">#404040</Color>
    <Color x:Key="ButtonMouseOnColor">#606060</Color>
    <Color x:Key="DangerColor">#f77669</Color>
    <Color x:Key="ScrollBarThumbColor">#666666</Color>
    <Color x:Key="ScrollBarThumbMouseOverColor">#888888</Color>
    
    <!-- Brushes -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#202020"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#AAAAAA"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="White"/>
    
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource MouseOnColor}"/>
    <SolidColorBrush x:Key="ControlMouseOverBrush" Color="{StaticResource MouseOnColor}"/>
    <SolidColorBrush x:Key="ButtonMouseOverBrush" Color="{StaticResource ButtonMouseOnColor}"/>
    <SolidColorBrush x:Key="ControlDisabledForegroundBrush" Color="{StaticResource ButtonMouseOnColor}"/>
    <SolidColorBrush x:Key="ControlDisabledBackgroundBrush" Color="{StaticResource MouseOnColor}"/>
    
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="SubtleBorderBrush" Color="#80000000"/> <!-- Darker subtle border -->
    
    <!-- Special Brushes -->
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="DarkTextBrush" Color="#E0E0E0"/> <!-- In dark mode, 'DarkText' should technically be light to be visible -->
    <SolidColorBrush x:Key="MediumTextBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="HighlightBrush" Color="#FF3585FF"/>
    
    <!-- ScrollBar Brushes -->
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="{StaticResource ScrollBarThumbColor}"/>
    <SolidColorBrush x:Key="ScrollBarThumbMouseOverBrush" Color="{StaticResource ScrollBarThumbMouseOverColor}"/>

</ResourceDictionary>
