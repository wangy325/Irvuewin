<helper:LocationAwareWindow
    x:Class="Irvuewin.Views.AddChannel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helper="clr-namespace:Irvuewin.Helpers"
    xmlns:vm="clr-namespace:Irvuewin.ViewModels"
    xmlns:m="clr-namespace:Irvuewin.Models.Unsplash"
    xmlns:converters="clr-namespace:Irvuewin.Helpers.Converters"
    xmlns:controls="clr-namespace:Irvuewin.Controls"
    mc:Ignorable="d"
    Title="{Binding Source={x:Static helper:Localization.Instance}, Path=[Add_Channel]}"
    Height="450" Width="400"
    Background="{DynamicResource WindowBackgroundBrush}"
    ShowInTaskbar="False" ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">

    <helper:LocationAwareWindow.DataContext>
        <vm:AddChannelViewModel />
    </helper:LocationAwareWindow.DataContext>

    <helper:LocationAwareWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
            </ResourceDictionary.MergedDictionaries>

            <converters:TextToVisibilityConverter x:Key="TextToVisibilityConverter" />

            <DataTemplate x:Key="ResolvingChannelsTemplate"
                          DataType="{x:Type m:UnsplashChannel}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <RadioButton x:Name="PART_RadioButton"
                                 Grid.Column="0"
                                 IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected, Mode=TwoWay}"
                                 IsEnabled="{TemplateBinding IsEnabled}"
                                 Margin="5,0,0,0"
                                 HorizontalAlignment="Right"
                                 Style="{StaticResource RadioStyle}" />
                    <Image Grid.Column="1"
                           Source="{Binding  Path= CoverPhoto.Urls.Small}">
                        <Image.Style>
                            <Style TargetType="Image">
                                <Setter Property="Stretch" Value="UniformToFill" />
                                <Setter Property="Clip">
                                    <Setter.Value>
                                        <RectangleGeometry RadiusX="5" RadiusY="5" Rect="5,0,40,40" />
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Image.Style>
                    </Image>
                    <TextBlock Grid.Column="2"
                               Text="{Binding Title}"
                               Style="{StaticResource TextBlockStyle}"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap">
                        <TextBlock.ToolTip>
                            <ToolTip Style="{StaticResource ToolTipStyle}"
                                     Content="{Binding Title}" />
                        </TextBlock.ToolTip>
                    </TextBlock>

                    <Path Grid.Column="3"
                          Data="{StaticResource Icon_Eye}"
                          Fill="{DynamicResource PrimaryTextBrush}"
                          Stretch="Uniform"
                          Width="14" Height="14" Margin="5,0" />
                    <TextBlock Grid.Column="4"
                               Padding="0,0,20,0"
                               Text="{Binding TotalPhotos}"
                               Style="{StaticResource TextBlockStyle}"
                               HorizontalAlignment="Right">
                    </TextBlock>
                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="EmptyDataTemplate"
                          DataType="{x:Type vm:AddChannelViewModel}">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="{Binding Source={x:Static helper:Localization.Instance}, Path=[Add_Channel_Result_Placeholder]}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontStyle="Italic"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                    <Button Content="{Binding Source={x:Static helper:Localization.Instance}, Path=[Add_Channel_Unsplash_Link]}"
                            Width="150"
                            Command="{Binding OpenUnsplashCommand}"
                            Style="{StaticResource BottomButtonStyle}" />
                </StackPanel>
            </DataTemplate>

            <Style x:Key="ChannelMultipleSelectorStyle" TargetType="ListBox" BasedOn="{StaticResource ListBoxStyle}">
                <Setter Property="Margin" Value="0,5, 0,0" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="SelectionMode" Value="Multiple" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="5">
                                <Grid>
                                    <ScrollViewer x:Name="ListBoxScrollViewer"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                    <ContentControl x:Name="EmptyDataContent"
                                                    Content="{TemplateBinding DataContext}"
                                                    ContentTemplate="{StaticResource EmptyDataTemplate}"
                                                    IsTabStop="False"
                                                    Visibility="Collapsed" />
                                </Grid>

                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="ListBox.ItemsSource" Value="{x:Null}">
                                    <Setter TargetName="EmptyDataContent" Property="Visibility" Value="Visible" />
                                </Trigger>
                                <Trigger Property="ListBox.HasItems" Value="False">
                                    <Setter TargetName="EmptyDataContent" Property="Visibility" Value="Visible" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ChannelSelectorBoxItemStyle"
                   TargetType="ListBoxItem"
                   BasedOn="{StaticResource ListBoxItemStyle}">
                <Setter Property="Margin" Value="0,2" />
            </Style>
        </ResourceDictionary>
    </helper:LocationAwareWindow.Resources>


    <TabControl Margin="20, 0" BorderThickness="0" Background="{DynamicResource WindowBackgroundBrush}">

        <TabItem>
            <TabItem.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Background="{DynamicResource WindowBackgroundBrush}"
                                        BorderThickness="0"
                                        BorderBrush="{DynamicResource SecondaryTextBrush}"
                                        Padding="3"
                                        CornerRadius="2">
                                    <ContentPresenter ContentSource="Header" />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabItem.Resources>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="50" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.Resources>
                        <Style x:Key="PlaceholderTextBoxStyle" TargetType="TextBox">
                            <Setter Property="Background" Value="{DynamicResource TransparentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TextBox">
                                        <Grid>
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="2" />
                                            <ScrollViewer x:Name="PART_ContentHost"
                                                          Focusable="False"
                                                          HorizontalScrollBarVisibility="Hidden"
                                                          VerticalScrollBarVisibility="Hidden" />
                                            <TextBlock x:Name="PlaceholderText"
                                                       Text="{TemplateBinding Tag}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       IsHitTestVisible="False"
                                                       Margin="{TemplateBinding Padding}"
                                                       VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                       HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontStyle" Value="Italic" />
                                                        <Style.Triggers>
                                                            <!-- 当 TextBox 有文本时隐藏占位符 -->
                                                            <DataTrigger
                                                                Binding="{Binding Text , RelativeSource={RelativeSource AncestorType=TextBox}, Converter={StaticResource TextToVisibilityConverter}}"
                                                                Value="Collapsed">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <!-- 当 TextBox 获得焦点时隐藏占位符 -->
                                                            <DataTrigger
                                                                Binding="{Binding IsFocused, RelativeSource={RelativeSource AncestorType=TextBox}}"
                                                                Value="True">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>

                        <Style x:Key="ButtonStyles" TargetType="Button" BasedOn="{StaticResource BottomButtonStyle}">
                            <Setter Property="Height" Value="24" />
                            <Setter Property="Width" Value="24" />
                        </Style>
                    </Grid.Resources>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="40" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 x:Name="InputChannelUrl"
                                 Style="{StaticResource PlaceholderTextBoxStyle}"
                                 Tag="{Binding Source={x:Static helper:Localization.Instance}, Path=[Add_Channel_Input_Placeholder]}"
                                 Text=""
                                 HorizontalAlignment="Stretch"
                                 VerticalAlignment="Center"
                                 Padding="5"
                                 KeyDown="InputChannelUrl_KeyDown" />
                        <Button Grid.Column="1"
                                Style="{StaticResource ButtonStyles}"
                                Click="ResolvingChannel_Click"
                                Content="{Binding Resolving}" />
                    </Grid>
                </Grid>

                <StackPanel Grid.Row="1">
                    <StackPanel.Resources>
                        <Style x:Key="HintTextStyle" TargetType="TextBlock">
                            <Setter Property="FontStyle" Value="Italic" />
                            <Setter Property="Foreground" Value="Gray" />
                            <Setter Property="FontSize" Value="10" />
                            <Setter Property="Padding" Value="5,0,0,5" />
                        </Style>
                    </StackPanel.Resources>
                    <TextBlock Text="{Binding Source={x:Static helper:Localization.Instance}, Path=[Add_Channel_Instruction]}"
                               Style="{StaticResource HintTextStyle}" />
                    <TextBlock Text="{Binding Hint1}"
                               Style="{StaticResource HintTextStyle}" />
                    <TextBlock Text="{Binding Hint2}"
                               Style="{StaticResource HintTextStyle}" />
                </StackPanel>

                <Separator Grid.Row="2" Style="{StaticResource SeparatorStyle}" />


                <ListBox Grid.Row="3"
                         x:Name="PreChannelsListBox"
                         helper:ListBoxSelectedItemsBehavior.BindableSelectedItems="{Binding SelectedChannels, Mode=TwoWay}"
                         Style="{StaticResource ChannelMultipleSelectorStyle}"
                         ItemsSource="{Binding PreChannels}"
                         ItemContainerStyle="{StaticResource ChannelSelectorBoxItemStyle}"
                         ItemTemplate="{StaticResource ResolvingChannelsTemplate}">

                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.Resources>

                    </ListBox.Resources>
                </ListBox>

                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <controls:LoadingAnimation Grid.Column="0"
                                               Height="15"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               IsLoading="{Binding IsLoading}" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right">

                        <Button Content="{Binding Source={x:Static helper:Localization.Instance}, Path=[Uni_Cancel]}"
                                Style="{StaticResource BottomButtonStyle}"
                                Click="CancelAddChannel_Click" />
                        <Button Content="{Binding Source={x:Static helper:Localization.Instance}, Path=[Add_Channel_Confirm]}"
                                Style="{StaticResource BottomButtonStyle}"
                                Click="AddChannel_Click" />
                    </StackPanel>
                </Grid>
            </Grid>
        </TabItem>

    </TabControl>
</helper:LocationAwareWindow>