<helpers:LocationAwareWindow
    x:Class="Irvuewin.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="clr-namespace:Irvuewin"
    xmlns:controls="clr-namespace:Irvuewin.Controls"
    xmlns:helpers="clr-namespace:Irvuewin.Helpers"
    xmlns:viewModels="clr-namespace:Irvuewin.ViewModels"
    mc:Ignorable="d"
    Title="Settings" Icon="/Icons/application_64.ico"
    Height="450" Width="350" MinWidth="200" MaxWidth="350"
    Background="WhiteSmoke"
    ShowInTaskbar="False" ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen">

    <helpers:LocationAwareWindow.DataContext>
        <viewModels:SettingsViewModel />
    </helpers:LocationAwareWindow.DataContext>

    <helpers:LocationAwareWindow.Resources>
        <!--合并资源-->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/Generic.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </helpers:LocationAwareWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="20" BorderThickness="0" Background="WhiteSmoke">
            <TabItem Header="通用"
                     helpers:TabItemHelper.IconSource="/Icons/settings/general.ico"
                     Style="{StaticResource TabStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>


                    <Separator Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="5" Margin="0, 10" />
                    <Label Grid.Row="1" Grid.Column="0"
                           Content="多显示器:"
                           Style="{StaticResource LabelStyle}" />
                    <RadioButton Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                 Name="SameWallpaperButton"
                                 Content="相同壁纸"
                                 GroupName="multiDisplay"
                                 IsChecked="{Binding MultiDisplay, 
                                            Mode=TwoWay,
                                            Converter={StaticResource Byte2BoolConverter},
                                            ConverterParameter=0,
                                            UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource RadioStyle}" />
                    <RadioButton Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2"
                                 Name="DifferentWallpaperButton"
                                 Content="不同壁纸"
                                 GroupName="multiDisplay"
                                 IsChecked="{Binding MultiDisplay,
                                            Mode=TwoWay,
                                            Converter={StaticResource Byte2BoolConverter},
                                            ConverterParameter=1,
                                            UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource RadioStyle}" />

                    <Label Grid.Row="2" Grid.Column="0"
                           Content="壁纸显示模式:"
                           Style="{StaticResource LabelStyle}" />
                    <RadioButton Grid.Row="2" Grid.Column="1"
                                 Name="FillRadioButton"
                                 Content="填充"
                                 GroupName="DisplayStyle"
                                 IsChecked="{Binding WallpaperMode,
                                           Mode=TwoWay,
                                           Converter={StaticResource Byte2BoolConverter},
                                           ConverterParameter=0,
                                           UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource RadioStyle}" />
                    <RadioButton Grid.Row="2" Grid.Column="2"
                                 Name="FitRadioButton" Content="适应"
                                 GroupName="DisplayStyle"
                                 IsChecked="{Binding WallpaperMode,
                                           Mode=TwoWay,
                                           Converter={StaticResource Byte2BoolConverter},
                                           ConverterParameter=1,
                                           UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource RadioStyle}" />
                    <RadioButton Grid.Row="2" Grid.Column="3"
                                 Name="StretchRadioButton"
                                 Content="拉伸"
                                 GroupName="DisplayStyle"
                                 IsChecked="{Binding WallpaperMode,
                                            Mode=TwoWay,
                                            Converter={StaticResource Byte2BoolConverter},
                                            ConverterParameter=2,
                                            UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource RadioStyle}" />
                    <!--<RadioButton Grid.Row="1" Grid.Column="4" 
                                 Name="CenterRadioButton" 
                                 Content="居中" 
                                 GroupName="DisplayStyle" 
                                 Style="{StaticResource RadioStyle}"/>
                    <RadioButton Grid.Row="1" Grid.Column="5" 
                                 Name="TileRadioButton" 
                                 Content="平铺" 
                                 GroupName="DisplayStyle" 
                                 Style="{StaticResource RadioStyle}"/>-->

                    <Label Grid.Row="3" Grid.Column="0"
                           Content="打开保存的壁纸:"
                           Style="{StaticResource LabelStyle}" />
                    <CheckBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2"
                              Name="OpenSavedWallpaper"
                              Content="Enable"
                              IsChecked="{Binding OpenSavedWallpaper, 
                                        Mode=TwoWay,
                                        UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource CheckBoxStyle}" />

                    <Label Grid.Row="4" Grid.Column="0"
                           Content="壁纸保存路径:"
                           Style="{StaticResource LabelStyle}" />
                    <Button Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2"
                            Name="BrowseWallpaperSavePathButton"
                            Content="选择..."
                            Style="{StaticResource ButtonStyle}"
                            Click="BrowseWallpaperSavePathButton_Click" />

                    <controls:PathDisplayControl Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="5"
                                                 x:Name="PathDisplayControl"
                                                 HorizontalAlignment="Left"
                                                 VerticalAlignment="Center"
                                                 Width="286"
                                                 FullPath="{Binding WallpaperSavedPath}">
                        <controls:PathDisplayControl.ToolTip>
                            <ToolTip Style="{StaticResource ToolTipStyle}">
                                <TextBlock Text="{Binding WallpaperSavedPath}" />
                            </ToolTip>
                        </controls:PathDisplayControl.ToolTip>
                    </controls:PathDisplayControl>

                    <Separator Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="5" Margin="0, 10" />

                    <Label Grid.Row="8" Grid.Column="0"
                           Content="随Windows启动:"
                           Style="{StaticResource LabelStyle}" />
                    <CheckBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="2"
                              Name="LaunchAtLoginCheckBox"
                              Content="Enable"
                              IsChecked="{Binding LaunchAtLogin,
                                         Mode=TwoWay,
                                         UpdateSourceTrigger=PropertyChanged}"
                              Style="{StaticResource CheckBoxStyle}" />

                    <!--<Label Grid.Row="10" Grid.Column="4"
                           Content="{Binding WallpaperMode, Mode=OneWay}" 
                           Style="{StaticResource LabelStyle}"/>-->


                </Grid>
            </TabItem>
            <TabItem Header="过滤"
                     helpers:TabItemHelper.IconSource="/Icons/settings/filter.ico"
                     Style="{StaticResource TabStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />

                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="Auto" MinWidth="80" />
                        <ColumnDefinition Width="Auto" MinWidth="80" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Separator Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Margin="0, 10" />

                    <Label Grid.Row="1" Grid.Column="0"
                           Content="壁纸比例偏好:"
                           Style="{StaticResource LabelStyle}" />
                    <ComboBox Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                              Name="ImageOrientationPreference"
                              Style="{StaticResource ComboBoxStyle}"
                              SelectedIndex="{Binding WallpaperOrientation, 
                                                      Mode=TwoWay, 
                                                      UpdateSourceTrigger=PropertyChanged}">
                        <ComboBoxItem Content="横向" Style="{StaticResource ComboBoxItemStyle}" />
                        <ComboBoxItem Content="纵向" Style="{StaticResource ComboBoxItemStyle}" />
                        <ComboBoxItem Content="横向和纵向" Style="{StaticResource ComboBoxItemStyle}" />
                    </ComboBox>

                    <Label Grid.Row="2" Grid.Column="0"
                           Content="智能过滤:"
                           Style="{StaticResource LabelStyle}" />
                    <ComboBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                              Name="SmartFilter"
                              Style="{StaticResource ComboBoxStyle}"
                              SelectedIndex="{Binding SmartFilter,
                                                      Mode=TwoWay,
                                                      UpdateSourceTrigger=PropertyChanged}">
                        <ComboBoxItem Content="无" Style="{StaticResource ComboBoxItemStyle}" />
                        <ComboBoxItem Content="过滤人像" Style="{StaticResource ComboBoxItemStyle}" />
                        <ComboBoxItem Content="过滤人像和全身照" Style="{StaticResource ComboBoxItemStyle}" />
                    </ComboBox>

                    <Label Grid.Row="3" Grid.Column="0"
                           Content="壁纸最小分辨率:"
                           Style="{StaticResource LabelStyle}" />
                    <ComboBox Grid.Row="3" Grid.Column="1"
                              Name="MinimumResolution"
                              Style="{StaticResource ComboBoxStyle}"
                              SelectedValue="{Binding MinResolution,
                                                     Mode=TwoWay,
                                                     Converter={StaticResource Float2StringConverter},
                                                     UpdateSourceTrigger=PropertyChanged}"
                              SelectedValuePath="Content">
                        <ComboBoxItem Content="100%" Style="{StaticResource ComboBoxItemStyle}" />
                        <ComboBoxItem Content="90%" Style="{StaticResource ComboBoxItemStyle}" />
                        <ComboBoxItem Content="80%" Style="{StaticResource ComboBoxItemStyle}" />
                    </ComboBox>
                    <Label Grid.Row="3" Grid.Column="2"
                           Content="显示器分辨率"
                           Style="{StaticResource LabelStyle}"
                           HorizontalAlignment="Left" />

                    <!--<TextBox Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" 
                           Text="{Binding MinResolution}"/>-->

                </Grid>
            </TabItem>
            <TabItem Header="关于"
                     helpers:TabItemHelper.IconSource="/Icons/settings/about.ico"
                     Style="{StaticResource TabStyle}">
                <Grid Margin="10">
                    <Label Content="An Irvue like application for Window..." />
                </Grid>
            </TabItem>
        </TabControl>

        <!--<StackPanel Grid.Row="1" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Margin="0,0,20,20">
            <Button Content="取消" 
                    Name="CancelSettingsButton" 
                    Style="{StaticResource BottomButtonStyle}" 
                    Click="CancelSettingsButton_Click"/>
            <Button Content="保存" 
                    Name="SaveSettingsButton" 
                    Style="{StaticResource BottomButtonStyle}" 
                    Click="SaveSettingsButton_Click"/>
        </StackPanel>-->

    </Grid>
</helpers:LocationAwareWindow>