<Application x:Class="Irvue_win.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Irvue_win"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <tb:TaskbarIcon
            x:Key="NotifyIcon"  
            ToolTipText="Irvuewin" 
            IconSource="/icons/tray.ico" 
            TrayLeftMouseUp="NotifyIcon_TrayMouseClick">

            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="立即更换壁纸" Name="ChangeNowMenuItem" Click="ChangeWallpaperNowMenuItem_Click"/>
                    <MenuItem Header="使用上一张壁纸" Name="LoadPreviousWallpaper" Click="LoadPreviousWallpaper_Click"/>
                    <Separator/>
                    <MenuItem Header="壁纸更换间隔" Name="WallpaperChangeInterval" Click="WallpaperChangeInterval_Click"/>
                    <Separator/>
                    <MenuItem Header="设置" Name="SettingsMenuItem" Click="SettingsMenuItem_Click"/>
                    <Separator/>
                    <MenuItem Header="退出" Name="ExitMenuItem" Click="ExitMenuItem_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Application.Resources>
</Application>
