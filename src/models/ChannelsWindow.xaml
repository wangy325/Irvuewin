<src:LocationAwareWindow  xmlns:src="clr-namespace:Irvue_win.src" x:Class="Irvue_win.src.models.ChannelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Irvue_win"
        xmlns:models="clr-namespace:Irvue_win.src.models" 
        mc:Ignorable="d"
        Title="Channels" Icon="/icons/application_64.ico"
        Height="450" Width="800" MinWidth="500"
        Background="WhiteSmoke" ShowInTaskbar="False" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        >

    <src:LocationAwareWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/src/models/Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </src:LocationAwareWindow.Resources>

    <Grid Margin="20, 0, 0, 10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>



        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>
            <ListBox Grid.Column="0" Grid.Row="0"
                     Margin="0,0,0,10"
                     SelectionMode="Single"
                     Style="{StaticResource {x:Type ListBox}}">
                <ListBoxItem Content="频道1"/>
                <ListBoxItem Content="频道2"/>
                <ListBoxItem Content="频道3"/>
            </ListBox>
            <StackPanel Grid.Column="0" Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="+" 
                        Width="30"
                        Style="{StaticResource BottomButtonStyle}"/>
                <Button Content="-" 
                        Width="30"
                        Style="{StaticResource BottomButtonStyle}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Label Grid.Column="0" Grid.Row="0"
                   Content="频道名称"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"/>
            <Label Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="壁纸预览"/>
                    <TextBlock Grid.Column="1" Text="刷新"/>
                </Grid>
            </Label>
            <ScrollViewer Grid.Row="2">
                <ItemsControl ItemsSource="{Binding ImageUrls}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Image Source="{Binding}"
                           Width="200"
                           Margin="20"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</src:LocationAwareWindow>
