<src:LocationAwareWindow xmlns:src="clr-namespace:Irvuewin.src" x:Class="Irvuewin.src.models.ChannelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Irvuewin"
        xmlns:models="clr-namespace:Irvuewin.src.models" 
        mc:Ignorable="d"
        Title="Channels" Icon="/icons/application_64.ico"
        Height="450" Width="800" MinWidth="500"
        Background="WhiteSmoke" ShowInTaskbar="False" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    
    <!--<src:LocationAwareWindow.DataContext>
        <models:ChannelsWindow/>
    </src:LocationAwareWindow.DataContext>-->

    <src:LocationAwareWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/src/models/Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </src:LocationAwareWindow.Resources>

    <Grid Margin="20, 0, 0, 10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>



        <Grid Grid.Column="0" Margin="0,0,20,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>
            <ListBox Grid.Column="0" Grid.Row="0"
                     Margin="0,0,0,10"
                     SelectionMode="Single"
                     Style="{StaticResource {x:Type ListBox}}">
                <ListBoxItem Content="频道1"/>
                <ListBoxItem Content="频道2"/>
                <ListBoxItem Content="频道3"/>
            </ListBox>
            <StackPanel Grid.Column="0" Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="+" 
                        Width="30"
                        Style="{StaticResource BottomButtonStyle}"/>
                <Button Content="-" 
                        Width="30"
                        Style="{StaticResource BottomButtonStyle}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="30"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Label Grid.Column="0" Grid.Row="0"
                   Content="频道名称"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"/>
            <Label Grid.Row="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="壁纸预览"/>
                    <TextBlock Grid.Column="1" Text="刷新"/>
                </Grid>
            </Label>
            <ScrollViewer Grid.Row="2">
                <ItemsControl ItemsSource="{Binding ImageUrls}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Image Grid.Row="0" Source="{Binding}" Width="200" Margin="20, 20, 20, 0"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image Source="{Binding AuthorImageUrl}" Width="24" Height="24" Margin="0,0,5,0"/>
                                    <TextBox Text="{Binding Author}" Width="170" Style="{StaticResource TextBoxstyle}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</src:LocationAwareWindow>
