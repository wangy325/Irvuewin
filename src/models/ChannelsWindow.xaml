<local:LocationAwareWindow xmlns:local="clr-namespace:Irvuewin" x:Class="Irvuewin.models.ChannelsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Channels" Icon="/icons/application_64.ico" 
        Height="450" Width="800" MinWidth="500"
        Background="WhiteSmoke" ShowInTaskbar="False" ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    
    <!--<local:LocationAwareWindow.DataContext>
        <models:ChannelsWindow/>
    </local:LocationAwareWindow.DataContext>-->

    <local:LocationAwareWindow.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/src/models/Themes/Generic.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </local:LocationAwareWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>



        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="45"/>
            </Grid.RowDefinitions>
            <ListBox Grid.Column="0" Grid.Row="0"
                     ItemContainerStyle="{StaticResource ListBoxItemStyle}"
                     Style="{StaticResource ListBoxStyle}"
                     >
                <ListBoxItem Height="40">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/icons/application_64.ico" />
                        <Label Style="{StaticResource LabelStyle}">
                            <Label.Content>
                                <TextBlock Text="频道1" />
                            </Label.Content>
                        </Label>
                        <RadioButton IsEnabled="True" Style="{StaticResource RadioStyle}"/>
                    </StackPanel>
                </ListBoxItem>
                <ListBoxItem Content="频道2"/>
                <ListBoxItem Content="频道3"/>
            </ListBox>
            <StackPanel Grid.Column="0" Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="+" Width="35"
                        Style="{StaticResource BottomButtonStyle}"/>
                <Button Content="-" Width="35"
                        Style="{StaticResource BottomButtonStyle}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="50" />
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="壁纸预览" 
                           Margin="0"
                           VerticalContentAlignment="Center"
                           HorizontalContentAlignment="Left"
                           Style="{StaticResource LabelStyle}"/>
                    <Button Grid.Column="1"
                            Content="刷新" 
                            Width="50" Height="20"
                            Margin="0"
                            Style="{StaticResource BottomButtonStyle}"/>
                </Grid>
            </Grid>
            
            <ScrollViewer Grid.Row="1" Margin="0,0,0,10">
                <ItemsControl ItemsSource="{Binding Photos}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Image Grid.Row="0" 
                                       Source="{Binding Urls.Small}" 
                                       Width="200" Margin="10, 10, 20, 0"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" 
                                            VerticalAlignment="Center">
                                    <Image Width="24" Height="24" Margin="20,5,5,5" 
                                           Source="{Binding User.ProfileImage.Small}">
                                        <Image.Clip>
                                            <EllipseGeometry Center="12,12" RadiusX="12" RadiusY="12"/>
                                        </Image.Clip>
                                    </Image>
                                    <Label Content="{Binding User.Name}"
                                           Foreground="Gray"
                                           FontStyle="Italic"
                                           FontFamily="Segoe UI"
                                           Style="{StaticResource LabelStyle}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</local:LocationAwareWindow>
