<Window x:Class="Irvue_win.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Irvue_win"
        xmlns:hp="clr-namespace:Irvue_win.src.helper"
        mc:Ignorable="d"
        Title="Settings" Icon="/icons/application_64.ico" Height="450" Width="500"
        ShowInTaskbar="False" ResizeMode="NoResize">
    <Window.Resources>

        <Style x:Key="LabelStyle" TargetType="Label">
            <Setter Property="Margin" Value="0, 5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Right"/>
        </Style>
        <Style x:Key="RadioStyle" TargetType="RadioButton">
            <Setter Property="Margin" Value="5,10"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="RadioBorder"
                                    Width="13" Height="13"
                                    CornerRadius="7.5"
                                    Background="White"
                                    BorderBrush="LightGray"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    Margin="0,0,5,0">
                                <Grid>
                                    <Ellipse x:Name="RadioDot"
                                             Width="10" Height="10"
                                             Fill="Transparent"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <!--<Setter TargetName="RadioBorder" Property="Background" Value="#3585FF"/>-->
                                <Setter TargetName="RadioDot" Property="Fill" Value="#3585FF"/>
                            </Trigger>
                            <!-- 失焦时样式变化 -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                    <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <!--<Setter TargetName="RadioBorder" Property="Background" Value="#FFC0C0C0"/>-->
                                <Setter TargetName="RadioDot" Property="Fill" Value="#FF888888"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Margin" Value="5, 5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="CheckBox.Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Border"
                                    Width="15" Height="15"
                                    CornerRadius="2"
                                    Background="White"
                                    BorderBrush="LightGray"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    Margin="0,0,5,0">
                                <Grid>
                                    <Path x:Name="CheckMark"
                                          Data="M 2 7 L 6 11 L 12 3"
                                          Stroke="Transparent"
                                          StrokeThickness="2"
                                          StrokeEndLineCap="Round"
                                          StrokeStartLineCap="Round"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3585FF"/>
                                <Setter TargetName="CheckMark" Property="Stroke" Value="white"/>
                            </Trigger>
                            <!-- 失焦时样式变化 -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsActive, RelativeSource={RelativeSource AncestorType=Window}}" Value="False"/>
                                    <Condition Binding="{Binding IsChecked, RelativeSource={RelativeSource Self}}" Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background" Value="#FFC0C0C0"/>
                                <Setter TargetName="CheckMark" Property="Stroke" Value="#FF888888"/>
                            </MultiDataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="5, 10"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="DarkBlue"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Button.Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="xFileButton"
                                Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="xFileButton" Property="Background" Value="#FFBEE6FD"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TextBoxstyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Margin" Value="0, 5"/>
            <Setter Property="Background" Value="AntiqueWhite"/>
            <Setter Property="IsEnabled" Value="False"/>
        </Style>
        <Style x:Key="TabStyle" TargetType="TabItem">
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Gray"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="10,0">
                            <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Image x:Name="TabItemIconImage"
                                       Width="35" Height="35"
                                       Source="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(hp:TabItemHelper.IconSource)}"
                                       Margin="44,0"/>

                                <ContentPresenter x:Name="ContentSite"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              ContentSource="Header"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <!--<Setter TargetName="Bd" Property="Background" Value="LightGray"/>-->
                                <Setter Property="Foreground" Value="#3585FF"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3585FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="20" BorderThickness="0">
            <TabItem Header="通用设置" hp:TabItemHelper.IconSource="/icons/settings/general.ico" Style="{StaticResource TabStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>


                    <Separator Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="6" Margin="0, 10"/>
                    <Label Grid.Row="1" Grid.Column="0" Content="多显示器:" Style="{StaticResource LabelStyle}"/>
                    <RadioButton Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Name="SameWallpaperButton" Content="相同壁纸" GroupName="multiDisplay" Style="{StaticResource RadioStyle}"/>
                    <RadioButton Grid.Row="1" Grid.Column="3" Grid.ColumnSpan="2" Name="DifferentWallpaperButton" Content="不同壁纸" GroupName="multiDisplay" Style="{StaticResource RadioStyle}"/>

                    <Label Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="1" Content="壁纸显示模式:" Style="{StaticResource LabelStyle}"/>

                    <RadioButton Grid.Row="2" Grid.Column="1" Name="FillRadioButton" Content="填充" GroupName="DisplayStyle" Style="{StaticResource RadioStyle}"/>
                    <RadioButton Grid.Row="2" Grid.Column="2" Name="FitRadioButton" Content="适应" GroupName="DisplayStyle" Style="{StaticResource RadioStyle}"/>
                    <RadioButton Grid.Row="2" Grid.Column="3"  Name="StretchRadioButton" Content="拉伸" GroupName="DisplayStyle" Style="{StaticResource RadioStyle}"/>
                    <!--<RadioButton Grid.Row="1" Grid.Column="4" Name="CenterRadioButton" Content="居中" GroupName="DisplayStyle" Style="{StaticResource RadioStyle}"/>-->
                    <!--<RadioButton Grid.Row="1" Grid.Column="5" Name="TileRadioButton" Content="平铺" GroupName="DisplayStyle" Style="{StaticResource RadioStyle}"/>-->

                    <Label Grid.Row="3" Grid.Column="0" Content="打开保存的壁纸:" Style="{StaticResource LabelStyle}"/>
                    <CheckBox Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="2" Name="OpenSavedWapppaper" Content="Enable" Style="{StaticResource CheckBoxStyle}" />

                    <Label Grid.Row="4" Grid.Column="0" Content="壁纸保存路径:" Style="{StaticResource LabelStyle}"/>
                    <Button Grid.Row="4" Grid.Column="1" Name="BrowseWallpaperSavePathButton" Content="浏览..." Style="{StaticResource ButtonStyle}"/>
                    <TextBox Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="6" Name="WallpaperSavePathTextBox" Style="{StaticResource TextBoxstyle}"/>
                    <Separator Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="6" Margin="0, 10"/>
                    <Label Grid.Row="7" Grid.Column="0" Content="随Windows启动:" Style="{StaticResource LabelStyle}"/>
                    <CheckBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" Name="LaunchAtLoginCheckBox" Content="Enable" Style="{StaticResource CheckBoxStyle}"/>
                </Grid>
            </TabItem>
            <TabItem Header="关于" hp:TabItemHelper.IconSource="/icons/settings/about.ico" Style="{StaticResource TabStyle}">
                <Grid Margin="10">
                    <Label Content="关于软件的信息将在这里..."/>
                </Grid>
            </TabItem>
            <TabItem  Header="壁纸过滤" hp:TabItemHelper.IconSource="/icons/settings/filter.ico" Style="{StaticResource TabStyle}">
                <Grid Margin="10">
                    <Label Content="Unsplash 来源设置 UI 将在这里..."/>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="取消" Name="CancelSettingsButton" Width="80" Margin="0,0,10,0"/>
            <Button Content="保存" Name="SaveSettingsButton" Width="80"/>
        </StackPanel>

    </Grid>
</Window>